      "updated": 1774241841007,
      "link": null,
      "locked": false,
      "text": "export const logger = pino({\n  level: process.env.LOG_LEVEL || 'info',\n  transport: { target: 'pino-pretty', options: { colorize: true } },\n});\n",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "export const logger = pino({\n  level: process.env.LOG_LEVEL || 'info',\n  transport: { target: 'pino-pretty', options: { colorize: true } },\n});\n",
