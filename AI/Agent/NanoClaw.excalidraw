      "y": 9067.42817096939,
      "width": 812.7989501953125,
      "height": 280,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "dashed",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": "5EsdGFu49fNB7C3bWOGvA",
      "index": "bGt",
