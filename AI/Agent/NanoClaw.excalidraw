      "link": null,
      "locked": false,
      "text": "注册退出事件\nprocess.on(\"SIGTERM\"或\"SIGINT\", () => {\n    // 自定义async function shutdown()\n    proxyServer.close();\n    await queue.shutdown(1000);\n    for(c : channels) { await c.disconnect(); }\n    process.exit(0);\n})",
      "fontSize": 16,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "middle",
      "containerId": "WG_30JKp1vZd4AyizJffz",
      "originalText": "注册退出事件\nprocess.on(\"SIGTERM\"或\"SIGINT\", () => {\n    // 自定义async function shutdown()\n    proxyServer.close();\n    await queue.shutdown(1000);\n    for(c : channels) { await c.disconnect(); }\n    process.exit(0);\n})",
      "autoResize": true,
      "lineHeight": 1.25
    },
