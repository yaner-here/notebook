      "versionNonce": 35030805,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1774241841007,
      "link": null,
      "locked": false,
      "text": "定义匿名变量: ChannelOpts <TEMP> = {\n    registeredGroups = function() { return registeredGroups; },\n    getSessions = function() { return sessions; },\n    queue = queue,\n    onProcess = function(groupJid, proc, containerName, groupFolder) {\n        queue.registerProcess(groupJid, proc, containerName, groupFolder);\n    },\n    sendMessage = async function(jid, rawText) {\n        text = formatOutbound(rawText); // 移除<internal>标签\n        根据jid查找channel，调用channel.sendMessage(jid, text);\n    }\n}",
      "fontSize": 16,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "middle",
      "containerId": "6usAM0CYCLOaz4WSZVR-g",
      "originalText": "定义匿名变量: ChannelOpts <TEMP> = {\n    registeredGroups = function() { return registeredGroups; },\n    getSessions = function() { return sessions; },\n    queue = queue,\n    onProcess = function(groupJid, proc, containerName, groupFolder) {\n        queue.registerProcess(groupJid, proc, containerName, groupFolder);\n    },\n    sendMessage = async function(jid, rawText) {\n        text = formatOutbound(rawText); // 移除<internal>标签\n        根据jid查找channel，调用channel.sendMessage(jid, text);\n    }\n}",
      "autoResize": true,
      "lineHeight": 1.25
    },
