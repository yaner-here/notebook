      "versionNonce": 1138867765,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1774241841007,
      "link": null,
      "locked": false,
      "text": "定义匿名变量 IpcDeps <TEMP> = {\n    sendMessage = function(jid, text) : Promise {\n        调用jid所属channel的.sendMessage(jid, text);\n    }\n    registeredGroups = () => { return 全局变量registeredGroups; }\n    registerGroup = registerGroup\n    syncGroups = () => { 调用channels的所有channel.syncGroups()，同步群组名称; }\n    getAvailableGroups = function() : AvailableGroup[] { 通过chats获取所有可用群组; }\n    writeGroupsSnapshot = container-runner.ts的writeGroupsSnapShot()\n    onTaskChanged = 获取所有tasks，调用container-runner.ts的writeGroupsSnapShot()\n}",
      "fontSize": 16,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "middle",
      "containerId": "Scum83unhEwG_OFQ9p2X6",
      "originalText": "定义匿名变量 IpcDeps <TEMP> = {\n    sendMessage = function(jid, text) : Promise {\n        调用jid所属channel的.sendMessage(jid, text);\n    }\n    registeredGroups = () => { return 全局变量registeredGroups; }\n    registerGroup = registerGroup\n    syncGroups = () => { 调用channels的所有channel.syncGroups()，同步群组名称; }\n    getAvailableGroups = function() : AvailableGroup[] { 通过chats获取所有可用群组; }\n    writeGroupsSnapshot = container-runner.ts的writeGroupsSnapShot()\n    onTaskChanged = 获取所有tasks，调用container-runner.ts的writeGroupsSnapShot()\n}",
      "autoResize": true,
      "lineHeight": 1.25
    },
