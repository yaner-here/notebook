    {
      "id": "gCtGsemqB32LUdhypL3qp",
      "type": "text",
      "x": -1105.6244390861184,
      "y": 6983.030400665576,
      "width": 695.9995727539062,
      "height": 180,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "dashed",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
