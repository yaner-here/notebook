      "updated": 1774241841007,
      "link": null,
      "locked": false,
      "text": "state.isTaskContainer=true，state.runningTaskId = task.id, state.activeCount++;\n执行task的处理函数await task.fn()\nstate.isTaskContainer=false，state.runningTaskId = null, state.activeCount--;\n执行drainGroup(groupJid)",
      "fontSize": 16,
      "fontFamily": 8,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "95rNgIVlAUVG7UwRII9ia",
      "originalText": "state.isTaskContainer=true，state.runningTaskId = task.id, state.activeCount++;\n执行task的处理函数await task.fn()\nstate.isTaskContainer=false，state.runningTaskId = null, state.activeCount--;\n执行drainGroup(groupJid)",
      "autoResize": true,
      "lineHeight": 1.25
    },
