      "link": null,
      "locked": false,
      "text": "state.isTaskContainer=false，state.pendingMessages = false, state.activeCount++;\n执行全局变量提供的的处理函数await this.processMessagesFn();\nstate.isTaskContainer=false, state.activeCount--;\n执行drainGroup(groupJid)",
      "fontSize": 16,
      "fontFamily": 8,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "Tn7PqPa_vmnRAHXfMy79h",
      "originalText": "state.isTaskContainer=false，state.pendingMessages = false, state.activeCount++;\n执行全局变量提供的的处理函数await this.processMessagesFn();\nstate.isTaskContainer=false, state.activeCount--;\n执行drainGroup(groupJid)",
      "autoResize": true,
      "lineHeight": 1.25
