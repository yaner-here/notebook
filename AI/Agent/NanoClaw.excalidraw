    {
      "id": "EyNo9l8jW02k1MSSd5IgO",
      "type": "text",
      "x": -1088.0512577476975,
      "y": 7547.307291889117,
      "width": 727.99951171875,
      "height": 160,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "dashed",
      "roughness": 0,
