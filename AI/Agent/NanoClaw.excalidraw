    {
      "id": "88GMhGWSLlCjTBSExxTKH",
      "type": "text",
      "x": -1312.3126232434824,
      "y": 10110.160956060636,
      "width": 731.9996948242188,
      "height": 240,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": "5EsdGFu49fNB7C3bWOGvA",
      "index": "bDwG",
      "roundness": null,
      "seed": 1264307483,
      "version": 1478,
      "versionNonce": 1020882139,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1774241841007,
      "link": null,
      "locked": false,
      "text": "定义变量: ChannelOpts channelOpts = {\n    onMessage = function(chatJid, newMessage msg) {\n        1. 如果msg.content为\"/remote-control\"或\"/remote-control-end\"\n            则调用handleRemoteControl(...);\n        2. 如果msg来自于群组内的其它人，则向sender-allowlist.ts请求白名单做过滤\n        3. 如果未命中以上情况，则调用storeMessage()存储消息到数据库的messages表\n    },\n    onChatMetadata = function(chatJid, timestamp, name, channel, isGroup) {\n        调用storeChatMetadata(...)存储到数据库的chats表\n    }\n    registeredGroups = () => { return 全局变量registeredGroups; }\n}",
      "fontSize": 16,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "middle",
      "containerId": "ioLXcCtO8ZtMx_s7WXhe4",
      "originalText": "定义变量: ChannelOpts channelOpts = {\n    onMessage = function(chatJid, newMessage msg) {\n        1. 如果msg.content为\"/remote-control\"或\"/remote-control-end\"\n            则调用handleRemoteControl(...);\n        2. 如果msg来自于群组内的其它人，则向sender-allowlist.ts请求白名单做过滤\n        3. 如果未命中以上情况，则调用storeMessage()存储消息到数据库的messages表\n    },\n    onChatMetadata = function(chatJid, timestamp, name, channel, isGroup) {\n        调用storeChatMetadata(...)存储到数据库的chats表\n    }\n    registeredGroups = () => { return 全局变量registeredGroups; }\n}",
      "autoResize": true,
      "lineHeight": 1.25
    },
