      "text": "return args: string[] = {\n    \"run\", \"-i\", \"--rm\", \"--name\", \"{containerName}\"\n    \"-e\", \"TZ={timezone}\",\n    \"-e\", \"ANTHROPIC_BASE_URL=http://host.docker.internal:3001\"\n    \"-e\", \"ANTHROPIC_API_KEY={...}\", \"-e\", \"CLAUDE_CODE_OAUTH_TOKEN={...}\"\n    \"--add-host=host.docker.internal:host-gateway\"\n    \"--user\", \"{process.getuid()}:{process.getgid()}\"\n    \"-e\", \"HOME=/home/node\"\n    \"-v\", \"{mount.hostPath}:{mount.containerPath}:vo\"，由mount.readonly决定是否仅可读\n    \"nanoclaw-agent:latest\" // Docker镜像名称\n}",
