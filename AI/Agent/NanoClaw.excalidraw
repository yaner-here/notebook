    {
      "id": "trcG0EpSVqyu2cqHuKP_4",
      "type": "text",
      "x": -918.403553911447,
      "y": 5925.759600817831,
      "width": 487.20001220703125,
      "height": 140,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "dashed",
      "roughness": 0,
